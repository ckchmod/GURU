{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/model-gateway.schema.json",
  "title": "Model Gateway Policy Schema",
  "description": "Lightweight typed policy envelope and cost ledger for the local-first model gateway.",
  "type": "object",
  "definitions": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "PolicyEnvelope": {
      "type": "object",
      "required": [
        "tenant_id",
        "user_id",
        "task_type",
        "task_id",
        "request_id",
        "allowed_model_classes",
        "context_token_limit",
        "output_token_limit",
        "max_gpu_seconds",
        "max_budget",
        "cache_lookup_enabled",
        "trace_logging_enabled",
        "cost_ledger_enabled",
        "approval_gate_required",
        "data_sensitivity",
        "source_permission_check",
        "external_api_allowed"
      ],
      "properties": {
        "tenant_id": { "$ref": "#/definitions/nonEmptyString" },
        "user_id": { "$ref": "#/definitions/nonEmptyString" },
        "task_type": { "$ref": "#/definitions/nonEmptyString" },
        "task_id": { "$ref": "#/definitions/uuid" },
        "request_id": { "$ref": "#/definitions/uuid" },
        "allowed_model_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "context_token_limit": { "type": "integer", "minimum": 0 },
        "output_token_limit": { "type": "integer", "minimum": 0 },
        "max_gpu_seconds": { "type": "number", "minimum": 0 },
        "max_budget": { "type": "number", "minimum": 0 },
        "cache_lookup_enabled": { "type": "boolean" },
        "trace_logging_enabled": { "type": "boolean" },
        "cost_ledger_enabled": { "type": "boolean" },
        "approval_gate_required": { "type": "boolean" },
        "data_sensitivity": {
          "type": "string",
          "enum": ["public", "internal", "restricted", "phi_prohibited"]
        },
        "source_permission_check": { "type": "boolean" },
        "external_api_allowed": {
          "type": "boolean",
          "enum": [false]
        }
      },
      "additionalProperties": false
    },
    "CostLedgerEntry": {
      "type": "object",
      "required": [
        "request_id",
        "tenant_id",
        "user_id",
        "task_type",
        "task_id",
        "model_class",
        "provider_kind",
        "outcome",
        "input_tokens",
        "output_tokens",
        "gpu_seconds",
        "estimated_cost",
        "cache_hit",
        "external_api_used",
        "source_permission_status",
        "timestamp_utc"
      ],
      "properties": {
        "request_id": { "$ref": "#/definitions/uuid" },
        "tenant_id": { "$ref": "#/definitions/nonEmptyString" },
        "user_id": { "$ref": "#/definitions/nonEmptyString" },
        "task_type": { "$ref": "#/definitions/nonEmptyString" },
        "task_id": { "$ref": "#/definitions/uuid" },
        "model_class": { "$ref": "#/definitions/nonEmptyString" },
        "provider_kind": {
          "type": "string",
          "enum": ["local", "private_hosted", "external"]
        },
        "outcome": {
          "type": "string",
          "enum": ["executed", "cache_hit", "rejected", "approval_pending", "quota_exceeded"]
        },
        "rejection_reason": { "type": "string" },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "gpu_seconds": { "type": "number", "minimum": 0 },
        "estimated_cost": { "type": "number", "minimum": 0 },
        "cache_hit": { "type": "boolean" },
        "external_api_used": { "type": "boolean" },
        "approval_id": { "$ref": "#/definitions/uuid" },
        "source_permission_status": { "$ref": "#/definitions/nonEmptyString" },
        "timestamp_utc": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  },
  "oneOf": [
    { "$ref": "#/definitions/PolicyEnvelope" },
    { "$ref": "#/definitions/CostLedgerEntry" }
  ]
}
